{
  "name": "@gardinbe/config",
  "version": "0.1.0",
  "private": true,
  "description": "Shared TypeScript, linting, and formatting configuration.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/gardinbe/config.git"
  },
  "bin": {
    "gardinbe": "./dist/cli/index.mjs",
    "gardinbe-config": "./dist/cli/index.mjs"
  },
  "files": [
    "dist/"
  ],
  "type": "module",
  "sideEffects": false,
  "exports": {
    "./package.json": "./package.json",
    "./oxfmt": {
      "types": "./dist/oxfmt/config.d.mts",
      "default": "./dist/oxfmt/config.mjs"
    },
    "./oxlint": {
      "types": "./dist/oxlint/config.d.mts",
      "default": "./dist/oxlint/config.mjs"
    },
    "./stylelint": {
      "types": "./dist/stylelint/config.d.mts",
      "default": "./dist/stylelint/config.mjs"
    },
    "./tsconfig": "./dist/tsconfig/node.json",
    "./tsconfig/*": "./dist/tsconfig/*.json"
  },
  "scripts": {
    "build": "tsdown && node scripts/copy-tsconfig.ts",
    "fix": "oxlint --fix && oxfmt",
    "check": "tsc -b tsconfig.json && oxlint && oxfmt --check"
  },
  "dependencies": {
    "@types/node": "^25.7.0",
    "commander": "^14.0.3",
    "eslint-plugin-perfectionist": "^5.9.0",
    "oxfmt": "^0.49.0",
    "oxlint": "^1.64.0",
    "oxlint-tsgolint": "^0.22.1",
    "postcss-styled": "^0.34.0",
    "stylelint": "^17.11.0",
    "stylelint-config-recess-order": "^7.7.0",
    "stylelint-gamut": "^2.0.1",
    "stylelint-plugin-defensive-css": "^2.9.1",
    "stylelint-plugin-logical-css": "^2.1.0",
    "stylelint-use-nesting": "^6.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.12"
  },
  "devDependencies": {
    "tsdown": "^0.22.0"
  },
  "engines": {
    "node": ">=24.3.0"
  },
  "packageManager": "pnpm@11.1.1"
}
